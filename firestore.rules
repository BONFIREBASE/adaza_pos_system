rules_version = '2';

// ADAZA POS security rules — permission-based, with data-driven roles.
//
// - `roles/{roleId}` holds each role's permission list (Owner only writes it).
// - `users/{uid}` holds each account's role id + profile + status.
// - A user's effective permissions = the permissions of their role.
// - The reserved 'owner' role always has full access.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function hasAccess() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRoleId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner() {
      return hasAccess() && myRoleId() == 'owner';
    }

    // Whether the signed-in user's role grants permission p.
    function has(p) {
      return hasAccess() && (
        isOwner() ||
        (exists(/databases/$(database)/documents/roles/$(myRoleId()))
          && get(/databases/$(database)/documents/roles/$(myRoleId()))
              .data.permissions.hasAny([p]))
      );
    }

    // A product update that changes only stock (e.g. a cashier's sale).
    function onlyStockChanged() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['stockQuantity']);
    }

    // Role catalog: readable by any signed-in user; only the Owner manages it.
    match /roles/{roleId} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // Accounts. Managing requires 'manageUsers'. Owner accounts can only be
    // created/changed/removed by the Owner. Any user may edit only their own
    // name/photo.
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if
        (has('manageUsers')
          && (request.resource.data.role != 'owner' || isOwner())
          && (resource == null || resource.data.role != 'owner' || isOwner()))
        || (signedIn() && request.auth.uid == uid
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['name', 'photo', 'mustChangePassword']));
      allow delete: if has('manageUsers')
        && (resource.data.role != 'owner' || isOwner());
    }

    // Catalog: read by anyone signed-in; manage by 'manageProducts'. A cashier
    // (recordSales) may only decrement stock when recording a sale.
    match /products/{id} {
      allow read: if hasAccess();
      allow create, delete: if has('manageProducts');
      allow update: if has('manageProducts')
        || (has('recordSales') && onlyStockChanged());
    }

    match /sales/{id} {
      allow read: if hasAccess();
      allow create: if has('recordSales') || has('manageFinance');
      allow update, delete: if has('manageFinance');
    }

    match /finance/{id} {
      allow read: if hasAccess();
      allow create: if has('recordSales') || has('manageFinance');
      allow update, delete: if has('manageFinance');
    }
  }
}
