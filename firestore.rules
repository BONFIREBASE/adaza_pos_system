rules_version = '2';

// ADAZA POS security rules.
// - Business data (products, sales, finance) is readable/writable by any
//   authenticated user (Owner / Admin / Cashier).
// - The `users` collection holds each account's role and is writable only by
//   the Owner. The first Owner document is created once in the Firebase console.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function roleOf(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function hasAccess() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isOwner() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && roleOf(request.auth.uid) == 'owner';
    }

    // Owner or Admin — the roles allowed to manage the catalog.
    function canManage() {
      return hasAccess() && roleOf(request.auth.uid) in ['owner', 'admin'];
    }

    function isAdminActor() {
      return hasAccess() && roleOf(request.auth.uid) == 'admin';
    }

    // True when a product update only changes stock (e.g. a cashier's sale).
    function onlyStockChanged() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['stockQuantity']);
    }

    // Account roles + employment details. Anyone signed-in can read (to resolve
    // their own role). The Owner manages everyone; an Admin may manage only
    // Cashier accounts (cannot create/edit Owners or other Admins).
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner()
        || (isAdminActor()
            && request.resource.data.role == 'cashier'
            && (resource == null || resource.data.role == 'cashier'));
      // A user may edit only their own display name / photo.
      allow update: if signedIn() && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['name', 'photo']);
      allow delete: if isOwner()
        || (isAdminActor() && resource.data.role == 'cashier');
    }

    // Products: anyone signed-in can read (needed for sales/lookup). Only Owner
    // or Admin can create/edit/delete; a Cashier may only decrement stock when
    // recording a sale.
    match /products/{id} {
      allow read: if hasAccess();
      allow create, delete: if canManage();
      allow update: if canManage() || (hasAccess() && onlyStockChanged());
    }

    match /sales/{id} {
      allow read, write: if hasAccess();
    }
    match /finance/{id} {
      allow read, write: if hasAccess();
    }
  }
}
